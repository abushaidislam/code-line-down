{
  "manifest_version": 3,
  "name": "Line Counter",
  "version": "1.0.0",
  "description": "Count lines in the current page or selected text.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
